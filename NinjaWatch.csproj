<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>NinjaWatch</RootNamespace>
        <AssemblyName>NinjaWatch</AssemblyName>
        <!-- Embed the UAC manifest so Windows prompts for elevation on launch -->
        <ApplicationManifest>app.manifest</ApplicationManifest>
        <!-- Windows-only; P/Invoke against iphlpapi.dll requires Windows -->
        <Platforms>x64;x86</Platforms>
    </PropertyGroup>

    <ItemGroup>
        <!-- Copy appsettings.json to the output folder so it can be found at runtime -->
        <None Update="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

</Project>

